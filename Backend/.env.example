PORT=3000
MONGO_URI=mongodb://localhost:27017
MONGO_DBNAME=proyecto_horarios
JWT_SECRET=tu_jwt_secret

# URL del frontend que tiene la pantalla de reset
FRONTEND_RESET_PASSWORD_URL=http://localhost:5173/reset-password

# SMTP (opcional para envío de recuperación)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=usuario
SMTP_PASS=contrasena
SMTP_FROM="Proyecto Horarios <no-reply@example.com>"
